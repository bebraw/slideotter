#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

zero_oid="0000000000000000000000000000000000000000"
changed_files="$(mktemp)"
unique_changed_files="$(mktemp)"
trap 'rm -f "$changed_files" "$unique_changed_files"' EXIT

updates_seen=0

while read -r local_ref local_oid remote_ref remote_oid
do
  [ -n "${local_ref:-}" ] || continue
  [ "$local_oid" != "$zero_oid" ] || continue

  updates_seen=1

  if [ "$remote_oid" = "$zero_oid" ]; then
    base_oid="$(git merge-base "$local_oid" origin/main 2>/dev/null || true)"
    if [ -z "$base_oid" ]; then
      base_oid="$(git hash-object -t tree /dev/null)"
    fi
  else
    base_oid="$remote_oid"
  fi

  git diff --name-only "$base_oid" "$local_oid" >> "$changed_files"
done

if [ "$updates_seen" -eq 0 ]; then
  exit 0
fi

sort -u "$changed_files" > "$unique_changed_files"

docs_only=1
while read -r path
do
  [ -n "$path" ] || continue
  case "$path" in
    *.md|docs/*)
      ;;
    *)
      docs_only=0
      break
      ;;
  esac
done < "$unique_changed_files"

if [ "$docs_only" -eq 1 ]; then
  echo "Documentation-only push detected; skipping fast quality gate."
  exit 0
fi

echo "Running fast quality gate before push..."
npm run quality:gate:fast
