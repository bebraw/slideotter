{
  "name": "slideotter",
  "version": "0.1.0",
  "private": true,
  "description": "slideotter DOM-first browser presentation studio and demo deck.",
  "scripts": {
    "build:diagrams": "node scripts/render-diagrams.js",
    "build": "npm run build:diagrams && node scripts/build-deck.js",
    "build:all": "npm run build",
    "ci:local": "agent-ci run --quiet --jobs 1 --workflow .github/workflows/ci.yml",
    "ci:local:retry": "agent-ci retry",
    "validate:diagrams": "node scripts/render-diagrams.js",
    "validate:geometry": "node scripts/validate-geometry.js",
    "validate:text": "node scripts/validate-text.js",
    "validate:media-fixture": "node scripts/validate-media-fixture.js",
    "validate:deck-plan-fixture": "node scripts/validate-deck-plan-fixture.js",
    "validate": "npm run validate:diagrams && npm run validate:geometry && npm run validate:text && npm run validate:media-fixture && npm run validate:deck-plan-fixture",
    "baseline:render": "npm run build && node scripts/update-render-baseline.js",
    "validate:render": "npm run build && node scripts/validate-render.js",
    "validate:all": "npm run validate && npm run validate:render",
    "quality:gate:fast": "npm run validate",
    "quality:gate": "npm run validate && npm run validate:render",
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "screenshot:home": "node ./scripts/run-home-screenshot.mjs",
    "slides:migrate:json": "node scripts/migrate-slides-to-json.js",
    "studio:dev": "node studio/server/index.js",
    "studio:start": "node studio/server/index.js",
    "studio:build": "node studio/server/noop-build.js"
  },
  "devDependencies": {
    "@redwoodjs/agent-ci": "0.13.0",
    "playwright": "1.59.1"
  }
}
