{
  "name": "slideotter",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Local DOM-first presentation studio for grounded, themed, reviewable decks.",
  "vibeTemplate": {
    "updates": [
      "2026-06-12-affected-guardrails",
      "2026-06-13-affected-unit-tests",
      "2026-06-13-relative-stryker-concurrency",
      "2026-06-14-agent-ci-warm-cache",
      "2026-06-17-shared-affected-file-utils"
    ]
  },
  "main": "desktop/main.cjs",
  "files": [
    "desktop/",
    "dist/"
  ],
  "bin": {
    "slideotter": "./dist/bin/slideotter.mjs"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build:diagrams": "node scripts/render-diagrams.ts",
    "build": "npm run build:diagrams && node scripts/build-deck.ts",
    "build:all": "npm run build",
    "export:pptx": "node scripts/export-pptx.ts",
    "archive:update": "npm run build && node scripts/update-archive.ts",
    "analyze:loc": "node scripts/analyze-loc.ts",
    "ci:local": "agent-ci run --quiet --pause-on-failure --workflow .github/workflows/ci.yml",
    "ci:local:retry": "agent-ci retry",
    "diagnostics:codebase": "npm run diagnostics:readability; npm run diagnostics:health; npm run diagnostics:targets; npm run diagnostics:hotspots",
    "diagnostics:health": "fallow health --score --quiet --no-cache --workspace '!studio/client/**'",
    "diagnostics:health:full": "fallow health --score --quiet --no-cache",
    "diagnostics:hotspots": "fallow health --hotspots --quiet --no-cache",
    "diagnostics:targets": "fallow health --targets --quiet --no-cache",
    "diagnostics:readability": "fallow audit --max-crap 100 --quiet --no-cache",
    "test": "node --test --test-concurrency=1 tests/*.test.ts tests/*.test.mjs",
    "test:mutation": "stryker run",
    "test:mutation:dry": "stryker run --dryRunOnly",
    "test:coverage": "node scripts/check-service-coverage.ts",
    "validate:diagrams": "node scripts/render-diagrams.ts",
    "validate:slide-spec-fixture": "node scripts/validate-slide-spec-fixture.ts",
    "validate:geometry": "node scripts/validate-geometry.ts",
    "validate:text": "node scripts/validate-text.ts",
    "validate:media-fixture": "node scripts/validate-media-fixture.ts",
    "validate:slide-media-fixture": "node scripts/validate-slide-media-fixture.ts",
    "validate:client-fixture": "node scripts/validate-client-fixture.ts",
    "validate:deck-plan-fixture": "node scripts/validate-deck-plan-fixture.ts",
    "validate:fuzz-fixtures": "npm run fuzz:fixtures",
    "validate:visible-text-quality": "node scripts/validate-visible-text-quality.ts",
    "validate:type-safety": "node scripts/check-explicit-any.ts && node scripts/check-strict-types.ts",
    "validate:output-config": "node scripts/validate-output-config.ts",
    "validate:docs": "node scripts/validate-docs.ts",
    "validate:dead-code": "node scripts/validate-dead-code.ts",
    "validate:presentation-workflow": "node scripts/validate-presentation-workflow.ts",
    "validate:studio-layout": "node scripts/validate-studio-layout.ts",
    "validate:browser": "npm run studio:client:build && node scripts/validate-browser.ts all",
    "validate:browser:presentation": "npm run studio:client:build && node scripts/validate-browser.ts presentation",
    "validate:browser:studio": "npm run studio:client:build && node scripts/validate-browser.ts studio",
    "validate:cloud-hosting": "node scripts/validate-cloud-hosting.ts",
    "validate:cloud-smoke": "node scripts/validate-cloud-smoke.ts",
    "validate:static": "node scripts/run-parallel.mjs validate:diagrams validate:slide-spec-fixture validate:geometry validate:text validate:media-fixture validate:slide-media-fixture validate:client-fixture validate:deck-plan-fixture validate:fuzz-fixtures validate:visible-text-quality validate:type-safety validate:output-config validate:docs validate:dead-code validate:cloud-hosting validate:cloud-smoke",
    "validate": "npm run validate:static && npm run validate:browser",
    "baseline:render": "npm run build && node scripts/update-render-baseline.ts",
    "validate:render": "npm run build && node scripts/validate-render.ts",
    "validate:all": "npm run validate && npm run validate:render",
    "quality:affected": "node scripts/run-affected-guardrails.mjs",
    "quality:gate:fast": "node scripts/run-parallel.mjs typecheck test:coverage && npm run validate",
    "quality:gate": "node scripts/run-parallel.mjs typecheck test:coverage && npm run validate && npm run validate:render",
    "package:build": "node scripts/build-package.mjs",
    "package:smoke": "node scripts/package-smoke.mjs",
    "desktop:dev": "npm run package:build && env -u ELECTRON_RUN_AS_NODE electron .",
    "desktop:smoke": "npm run package:build && env -u ELECTRON_RUN_AS_NODE SLIDEOTTER_ELECTRON_SMOKE=1 electron .",
    "desktop:browsers": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium",
    "desktop:pack": "npm run package:build && npm run desktop:browsers && electron-builder --mac --dir",
    "desktop:dist": "npm run package:build && npm run desktop:browsers && electron-builder --mac",
    "demo:preflight": "node scripts/demo-preflight.ts",
    "demo:preflight:lmstudio": "node scripts/demo-preflight.ts --lmstudio",
    "demo:rehearse": "npm run demo:preflight && npm run validate:presentation-workflow",
    "fuzz:fixtures": "FUZZ_FAKE_PROVIDER=fixtures node scripts/fuzz-lmstudio-generation.ts",
    "fuzz:lmstudio:browser": "npm run studio:client:build && node scripts/fuzz-lmstudio-browser-creation.ts",
    "fuzz:lmstudio": "node scripts/fuzz-lmstudio-generation.ts",
    "prepack": "npm run package:build",
    "prepare": "node ./scripts/setup-git-hooks.mts",
    "screenshot:home": "node ./scripts/run-home-screenshot.mts",
    "studio:client:build": "vite build",
    "studio:client:watch": "vite build --watch",
    "studio:dev": "node scripts/run-studio-dev.mjs",
    "studio:start": "node scripts/run-studio-dev.mjs",
    "studio:build": "npm run studio:client:build",
    "cloud:client:build": "npm run studio:client:build",
    "cloud:check": "npm run cloud:client:build && wrangler deploy --config cloud/wrangler.toml --dry-run --outdir cloud/dist",
    "cloud:dev": "npm run cloud:client:build && wrangler dev --config cloud/wrangler.toml",
    "typecheck": "node scripts/check-strict-types.ts",
    "typecheck:strict": "tsc --noEmit",
    "website:dev": "wrangler dev --config website/wrangler.toml",
    "website:check": "wrangler deploy --config website/wrangler.toml --dry-run --outdir website/dist",
    "website:deploy": "wrangler deploy --config website/wrangler.toml"
  },
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "1.22.2",
    "@napi-rs/canvas": "1.0.1",
    "pdfjs-dist": "6.0.227",
    "playwright": "1.61.1",
    "pptxgenjs": "4.0.1",
    "sharp": "0.35.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "1.1.0",
    "@redwoodjs/agent-ci": "0.16.2",
    "@stryker-mutator/api": "9.6.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@types/node": "24.13.2",
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "fallow": "2.102.0",
    "gustwind": "0.121.0",
    "vite": "8.1.0",
    "wrangler": "4.104.0"
  },
  "overrides": {
    "gustwind": {
      "postcss": "8.5.15"
    }
  },
  "build": {
    "appId": "dev.slideotter.app",
    "productName": "slideotter",
    "asar": true,
    "files": [
      "desktop/**/*",
      "dist/**/*",
      "node_modules/playwright-core/.local-browsers/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "directories": {
      "output": "desktop-dist"
    }
  }
}
