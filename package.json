{
  "name": "presentation-template",
  "version": "0.1.0",
  "private": true,
  "description": "Demo presentation generator built around the imported pdf-slide-generator skill.",
  "scripts": {
    "build:diagrams": "node generator/render-diagrams.js",
    "build": "npm run build:diagrams && node generator/compile.js",
    "build:all": "npm run build",
    "validate:diagrams": "node generator/render-diagrams.js",
    "validate:geometry": "node generator/validate-geometry.js",
    "validate:text": "node generator/validate-text.js",
    "validate": "npm run validate:diagrams && npm run validate:geometry && npm run validate:text",
    "baseline:render": "npm run build && node generator/update-render-baseline.js",
    "validate:render": "npm run build && node generator/validate-render.js",
    "validate:all": "npm run validate && npm run validate:render",
    "quality:gate": "npm run validate && npm run validate:render",
    "slides:migrate:json": "node scripts/migrate-slides-to-json.js",
    "studio:dev": "node studio/server/index.js",
    "studio:start": "node studio/server/index.js",
    "studio:build": "node studio/server/noop-build.js"
  },
  "dependencies": {
    "pdfkit": "0.18.0",
    "pptxgenjs": "^3.12.0",
    "qrcode": "1.5.4"
  },
  "devDependencies": {
    "playwright": "1.59.1"
  }
}
